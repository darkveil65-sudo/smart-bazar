rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Auth helpers ────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // Reads role from custom token claim first, falls back to Firestore doc.
    // NOTE: getUserRole() must only be called when isSignedIn() is true.
    function getUserRole() {
      return request.auth.token.get('role', null) != null
        ? request.auth.token.role
        : get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'customer');
    }

    function isAdmin() {
      return isSignedIn() && (getUserRole() == 'admin' || getUserRole() == 'co-admin');
    }

    function isManager() {
      return isSignedIn() && getUserRole() == 'manager';
    }

    function isStore() {
      return isSignedIn() && getUserRole() == 'store';
    }

    function isDelivery() {
      return isSignedIn() && getUserRole() == 'delivery';
    }

    function isCustomer() {
      return isSignedIn() && getUserRole() == 'customer';
    }


    // ─── /users ──────────────────────────────────────────────────────────────

    match /users/{userId} {
      // Each user can read/update their own doc; admins/managers can read all
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        isAdmin() ||
        isManager()
      );

      // Self-registration (new customer creating their own doc)
      allow create: if isSignedIn() && request.auth.uid == userId && (
        // Customers can only create customer docs
        request.resource.data.get('role', 'customer') == 'customer' ||
        // Admins can create any role
        isAdmin()
      );

      // Admin can create any user doc (e.g., seeding staff)
      allow create: if isAdmin();

      // Users can update themselves (but NOT role/status/assignments); admins can update anyone
      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          request.auth.uid == userId &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status', 'assignedStores', 'assignedCategories', 'vendorStore', 'managerId'])
        )
      );

      allow delete: if isAdmin();
    }


    // ─── /stores ─────────────────────────────────────────────────────────────

    match /stores/{storeId} {
      // Anyone can browse stores (needed for the customer app)
      allow read: if true;

      // Only admins/managers can create/update/delete stores
      allow create, update, delete: if isAdmin() || isManager();
    }


    // ─── /categories ─────────────────────────────────────────────────────────

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() || isManager();
    }


    // ─── /subcategories ──────────────────────────────────────────────────────

    match /subcategories/{subCategoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() || isManager();
    }


    // ─── /products ───────────────────────────────────────────────────────────

    match /products/{productId} {
      // Products are publicly browsable
      allow read: if true;

      // Store owners, managers, and admins can create products
      allow create: if isSignedIn() && (
        isAdmin() ||
        isManager() ||
        (isStore() && request.resource.data.vendorId == request.auth.uid)
      );

      // Only the owning vendor, a manager, or admin can modify/delete
      allow update: if isSignedIn() && (
        isAdmin() ||
        isManager() ||
        (
          isStore() &&
          resource.data.vendorId == request.auth.uid &&
          request.resource.data.vendorId == request.auth.uid &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['vendorId', 'store'])
        )
      );

      allow delete: if isSignedIn() && (
        isAdmin() ||
        isManager() ||
        (isStore() && resource.data.vendorId == request.auth.uid)
      );
    }


    // ─── /orders ─────────────────────────────────────────────────────────────

    match /orders/{orderId} {
      // Admins and managers see all orders
      allow read: if isAdmin() || isManager();

      // Parties involved in the order can read it (restricted to assigned roles/records)
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.customerId ||
        request.auth.uid == resource.data.assignedManagerId ||
        (isStore() && request.auth.uid == resource.data.assignedVendorId) ||
        (isDelivery() && request.auth.uid == resource.data.assignedDeliveryBoyId)
      );

      // Customers can place orders for themselves
      allow create: if isCustomer() && request.auth.uid == request.resource.data.customerId;

      // Role-based status transitions
      allow update: if isSignedIn() && (
        isAdmin() ||
        isManager() ||
        // Customer can only cancel their own pending order
        (
          isCustomer() &&
          request.auth.uid == resource.data.customerId &&
          resource.data.status == 'pending' &&
          request.resource.data.status == 'cancelled' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelReason', 'updatedAt'])
        ) ||
        // Store owner can update orders assigned to their vendor ID (status/packedAt/updatedAt only)
        (
          isStore() &&
          request.auth.uid == resource.data.assignedVendorId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'packedAt', 'updatedAt'])
        ) ||
        // Delivery person can update orders assigned to them (status/deliveredAt/updatedAt only)
        (
          isDelivery() &&
          request.auth.uid == resource.data.assignedDeliveryBoyId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'deliveredAt', 'updatedAt'])
        )
      );

      allow delete: if isAdmin();
    }


    // ─── /applications ───────────────────────────────────────────────────────

    match /applications/{applicationId} {
      // Users can read their own applications
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;

      // Admins and managers can read all applications
      allow read: if isAdmin() || isManager();

      // Users can submit their own applications
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;

      // Admins and managers can approve/reject
      allow update: if isAdmin() || isManager();

      allow delete: if isAdmin();
    }


    // ─── /heroBanners ────────────────────────────────────────────────────────

    match /heroBanners/{bannerId} {
      // Anyone can read banners (shown on the customer home screen)
      allow read: if true;

      // Only admins/managers can manage banners
      allow create, update, delete: if isAdmin() || isManager();
    }


    // ─── /coupons ────────────────────────────────────────────────────────────

    match /coupons/{couponId} {
      // Any signed-in user can read coupons (to validate during checkout)
      allow read: if isSignedIn();

      // Only admins and managers can create, update, or delete coupons
      allow create, update, delete: if isAdmin() || isManager();
    }


    // ─── /config ─────────────────────────────────────────────────────────────
    // The app-wide config lives at /config/app (a single document)

    match /config/{configId} {
      // Any authenticated user can read config (delivery slots, min order, etc.)
      allow read: if isSignedIn();

      // Only admins can write config
      allow write: if isAdmin();
    }

    // ─── /reviews ────────────────────────────────────────────────────────────

    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.auth.uid == request.resource.data.customerId ||
        isAdmin()
      ) && reviewId == request.resource.data.orderId;
      allow update: if isSignedIn() && (
        (
          request.auth.uid == request.resource.data.customerId &&
          request.resource.data.customerId == resource.data.customerId &&
          reviewId == request.resource.data.orderId &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['customerId', 'orderId'])
        ) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ─── /notifications ──────────────────────────────────────────────────────

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin() || isManager());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isAdmin() ||
        isManager() ||
        (
          resource.data.userId == request.auth.uid &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'title', 'message', 'type', 'orderId', 'createdAt'])
        )
      );
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin() || isManager());
    }
  }
}