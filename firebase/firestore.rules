rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper function to get user role from Firestore document
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // Helper function to check if user has specific role
    function hasRole(role) {
      return isSignedIn() && (getUserRole() == role || request.auth.token.role == role);
    }
    
    // Helper function to check if user is admin or co-admin
    function isAdminOrCoAdmin() {
      let role = getUserRole();
      return role == 'admin' || role == 'co-admin' || request.auth.token.role == 'admin' || request.auth.token.role == 'co-admin';
    }
    
    // Helper function to check if user is manager
    function isManager() {
      return hasRole('manager');
    }
    
    // Helper function to check if user is store owner
    function isStore() {
      return hasRole('store');
    }
    
    // Helper function to check if user is delivery person
    function isDelivery() {
      return hasRole('delivery');
    }
    
    // Helper function to check if user is customer
    function isCustomer() {
      return hasRole('customer');
    }
    
    // Users collection
    match /users/{userId} {
      // Anyone can read their own data
      allow read: if isSignedIn() && request.auth.uid == userId;
      
      // Admins can read all users
      allow read: if isAdminOrCoAdmin();
      
      // Managers can read store and delivery users (needed for order assignment)
      allow read: if isSignedIn() && isManager();
      
      // Allow customer self-registration: new users can create their own doc with role 'customer'
      allow create: if isSignedIn() && request.auth.uid == userId && 
                   request.resource.data.role == 'customer';
      
      // Admins can create any user
      allow create: if isAdminOrCoAdmin();
      
      // Admins can update/delete users; users can update their own name
      allow update: if isAdminOrCoAdmin() || 
                   (isSignedIn() && request.auth.uid == userId && 
                    request.resource.data.keys().hasOnly(['name', 'email', 'role', 'createdAt', 'updatedAt']));
      allow delete: if isAdminOrCoAdmin();
    }
    
    // Categories collection (predefined, read-only for most)
    match /categories/{categoryId} {
      allow read: if true; // Publicly readable
      allow create, update, delete: if isAdminOrCoAdmin(); // Only admins can modify
    }
    
    // Products collection
    match /products/{productId} {
      allow read: if true; // Products are publicly browsable
      
      // Store owners can create products in their assigned category
      allow create: if isSignedIn() && 
                   (isStore() || isManager() || isAdminOrCoAdmin());
                   
      // Store owners can update/delete only their own products
      allow update, delete: if isSignedIn() &&
                           (isAdminOrCoAdmin() ||
                            (isStore() && resource.data.storeId == request.auth.uid) ||
                            isManager());
    }
    
    // Orders collection
    match /orders/{orderId} {
      // Admins and managers can read all orders
      allow read: if isSignedIn() && (isAdminOrCoAdmin() || isManager());
      
      // Users can read orders they are part of
      allow read: if isSignedIn() &&
                 (request.auth.uid == resource.data.customerId ||
                  request.auth.uid == resource.data.assignedManagerId ||
                  request.auth.uid == resource.data.assignedStoreId ||
                  request.auth.uid == resource.data.assignedDeliveryBoyId);
      
      // Store owners can read orders assigned to their store
      allow read: if isSignedIn() && isStore();
      
      // Delivery persons can read orders assigned to them
      allow read: if isSignedIn() && isDelivery();
                  
      // Customers can create orders
      allow create: if isSignedIn() && isCustomer();
      
      // Status transitions based on role
      allow update: if isSignedIn() &&
                   (
                    // Customer can cancel their own pending order
                    (isCustomer() && 
                     request.auth.uid == resource.data.customerId &&
                     resource.data.status == 'pending' &&
                     request.resource.data.status == 'cancelled') ||
                    
                    // Manager can assign/update orders
                    isManager() ||
                    
                    // Store owner can update orders assigned to them
                    (isStore() &&
                     request.auth.uid == resource.data.assignedStoreId) ||
                     
                    // Delivery person can update orders assigned to them
                    (isDelivery() &&
                     request.auth.uid == resource.data.assignedDeliveryBoyId) ||
                     
                    // Admins can make any changes
                    isAdminOrCoAdmin()
                   );
                   
      // Delete only for admins
      allow delete: if isAdminOrCoAdmin();
    }
    
    // Applications collection (for store/delivery boy applications)
    match /applications/{applicationId} {
      // Users can read their own applications
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      
      // Admins and managers can read all applications
      allow read: if isSignedIn() && (isAdminOrCoAdmin() || isManager());
      
      // Users can create their own applications
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      
      // Admins and managers can update application status (approve/reject)
      allow update: if isSignedIn() && (isAdminOrCoAdmin() || isManager());
      
      // Delete only for admins
      allow delete: if isAdminOrCoAdmin();
    }
  }
}